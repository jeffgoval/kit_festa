VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Origem canônica (sem barra). redirectTo do Auth → {VITE_PUBLIC_SITE_URL}/app/login
# Produção: https://festa.sistemasdigitais.com | Dev local: deixe vazio para usar localhost
VITE_PUBLIC_SITE_URL=

# Personal Access Token (Dashboard → Account → Access Tokens) com escopo auth_config_write.
# Opcional: usado por scripts/supabase-sync-auth-url.mjs para PATCH site_url / uri_allow_list via API.
SUPABASE_ACCESS_TOKEN=
